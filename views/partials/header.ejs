<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Veek</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
/* ================= CART COUNT ================= */
#cart-count{
  position:absolute;
  top:-8px;
  right:-10px;
  background:red;
  color:#fff;
  font-size:12px;
  min-width:18px;
  height:18px;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  font-weight:bold;
}

/* ================= TOP BAR ================= */
.top-bar{
  width:100%;
  background:#000;
  color:#fff;
  display:flex;
  justify-content:center;
  align-items:center;
  gap:10px;
  padding:6px 12px;
  font-size:12px;
  font-weight:700;
  position:fixed;
  top:0;
  z-index:2000;
  min-height:34px;
  letter-spacing:.5px;
  flex-wrap:wrap;
}

.sale-text{
  color:#ffd700;
}

.bar-divider{
  opacity:.45;
}

#countdown{
  color:#fff;
}

/* ================= NAVBAR ================= */
.navbar{
  width:100%;
  background:#111;
  color:#fff;
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:15px 5%;
  position:fixed;
  top:34px;
  z-index:1000;
  height:56px;
}

.logo{
  font-size:22px;
  font-weight:500;
}

/* nav links */
.mobile-nav-links{
  list-style:none;
  display:flex;
  gap:25px;
  margin:0;
}

.mobile-nav-links a{
  text-decoration:none;
  color:#fff;
  font-size:14px;
  transition:.3s;
}

.mobile-nav-links a:hover{
  opacity:.7;
}

/* icons */
.nav-icons{
  display:flex;
  gap:15px;
  font-size:14px;
  position:relative;
}

.nav-icons a{
  color:#fff;
  text-decoration:none;
}

/* menu button */
.mobile-menu-btn{
  display:none;
  font-size:28px;
  cursor:pointer;
  color:#fff;
  background:none;
  border:none;
  padding:0;
}

/* overlay */
.overlay{
  display:none;
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.6);
  z-index:999;
}

/* body spacing */
body{
  padding-top:90px;
}

/* ================= MOBILE ================= */
@media(max-width:768px){

  .top-bar{
    font-size:10px;
    gap:6px;
    padding:6px 8px;
  }

  .mobile-menu-btn{
    display:block;
  }

  .mobile-nav-links{
    position:fixed;
    top:90px;
    right:-100%;
    width:280px;
    height:calc(100vh - 90px);
    background:#000;
    flex-direction:column;
    align-items:center;
    gap:0;
    transition:right .4s ease;
    z-index:1001;
    padding:40px 20px;
    box-shadow:-5px 0 20px rgba(0,0,0,.5);
  }

  .mobile-nav-links.active{
    right:0;
  }

  .mobile-nav-links li{
    width:100%;
    margin-bottom:15px;
  }

  .mobile-nav-links a{
    display:block;
    width:100%;
    padding:15px 20px;
    font-size:18px;
    text-align:center;
    border-bottom:1px solid #333;
  }

  .mobile-nav-links a:hover{
    background:#333;
  }

  .nav-icons{
    position:absolute;
    right:80px;
    top:50%;
    transform:translateY(-50%);
  }
}
</style>
</head>

<body>

<!-- ================= TOP BAR ================= -->
<div class="top-bar">
  <span>FREE SHIPPING OVER 1499 EGP!</span>
  <span class="bar-divider">|</span>
  <span class="sale-text">UP TO SALE 20% OFF</span>
  <span class="bar-divider">|</span>
  <span id="countdown">Loading...</span>
</div>

<!-- overlay -->
<div class="overlay" id="overlay"></div>

<!-- ================= NAVBAR ================= -->
<nav class="navbar">

  <div class="logo">Veek</div>

  <button class="mobile-menu-btn" id="mobileMenuBtn">☰</button>

  <ul class="mobile-nav-links" id="mobileNavLinks">
    <li><a href="/">Home</a></li>
    <li><a href="/collections">Collections</a></li>
    <li><a href="/sale">SALE!</a></li>
    <li><a href="/contact">Contact</a></li>
    <li><a href="/size-guide">Size Guide</a></li>
    <li><a href="/help">Help?</a></li>
  </ul>

  <div class="nav-icons">
    <a href="/cart">
      <i class="fa fa-shopping-bag"></i>
      <span id="cart-count"><%= cartCount %></span>
    </a>
  </div>

</nav>

<!-- ================= JS ================= -->
<script>
document.addEventListener("DOMContentLoaded", function(){

  /* ========== MOBILE MENU ========== */
  const menuBtn = document.getElementById("mobileMenuBtn");
  const navLinks = document.getElementById("mobileNavLinks");
  const overlay = document.getElementById("overlay");

  menuBtn.addEventListener("click", function(){

    const active = navLinks.classList.contains("active");

    if(active){
      menuBtn.innerHTML = "☰";
      navLinks.classList.remove("active");
      overlay.style.display = "none";
      document.body.style.overflow = "";
    }else{
      menuBtn.innerHTML = "✕";
      navLinks.classList.add("active");
      overlay.style.display = "block";
      document.body.style.overflow = "hidden";
    }

  });

  overlay.addEventListener("click", function(){
    menuBtn.innerHTML = "☰";
    navLinks.classList.remove("active");
    overlay.style.display = "none";
    document.body.style.overflow = "";
  });

  /* ========== COUNTDOWN يبدأ 11 مساءً ========== */
  const countdownEl = document.getElementById("countdown");
  const now = new Date();

  let startDate = new Date(
    now.getFullYear(),
    now.getMonth(),
    now.getDate(),
    23,0,0,0
  );

  /* لو الساعة عدت 11 مساء يبدأ بكرة */
  if(now > startDate){
    startDate.setDate(startDate.getDate() + 1);
  }

  /* يومين من وقت البداية */
  const endDate = new Date(
    startDate.getTime() + (2 * 24 * 60 * 60 * 1000)
  );

  function updateCountdown(){

    const current = new Date();

    /* قبل بداية السيل */
    if(current < startDate){

      let diff = startDate - current;

      let h = Math.floor(diff / (1000*60*60));
      let m = Math.floor((diff / (1000*60)) % 60);
      let s = Math.floor((diff / 1000) % 60);

      countdownEl.innerHTML =
        "STARTS IN " +
        String(h).padStart(2,"0") + "H : " +
        String(m).padStart(2,"0") + "M : " +
        String(s).padStart(2,"0") + "S";

      return;
    }

    /* بعد البداية */
    let diff = endDate - current;

    if(diff <= 0){
      countdownEl.innerHTML = "SALE ENDED";
      return;
    }

    let d = Math.floor(diff / (1000*60*60*24));
    let h = Math.floor((diff / (1000*60*60)) % 24);
    let m = Math.floor((diff / (1000*60)) % 60);
    let s = Math.floor((diff / 1000) % 60);

    countdownEl.innerHTML =
      d + "D : " +
      String(h).padStart(2,"0") + "H : " +
      String(m).padStart(2,"0") + "M : " +
      String(s).padStart(2,"0") + "S";
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);

});
</script>

</body>
</html>
