<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Your Cart</title>
  <style>
    body { font-family: Arial; margin:0; padding:0; background:#f4f4f4; }
    header { background:#000; color:#fff; padding:15px 20px; display:flex; justify-content:space-between; align-items:center; }
    header h1 { margin:0; font-size:22px; }
    #cart-count { background:red; color:white; width:18px; height:18px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:bold; }

    .cart-container { display:flex; flex-direction:column; gap:20px; max-width:800px; margin:20px auto; }
    .cart-item { display:flex; gap:20px; align-items:center; border:1px solid #ccc; padding:10px; border-radius:10px; background:#fff; position:relative; }
    .cart-item img { width:100px; height:100px; object-fit:cover; border-radius:10px; }
    .cart-details h4 { margin:0; font-size:18px; }
    .cart-details p { margin:5px 0; }

    .remove-btn { position:absolute; top:10px; right:10px; background:#dc3545; color:#fff; border:none; padding:5px 10px; border-radius:5px; cursor:pointer; }
    .remove-btn:hover { background:#c82333; }

    .checkout-btn { align-self:flex-end; padding:10px 20px; background:#007bff; color:#fff; text-decoration:none; border-radius:5px; }
    .checkout-btn:hover { background:#0056b3; }
/* =========================
   MOBILE RESPONSIVE FIX
========================= */

@media (max-width: 768px) {

  header {
    flex-direction: column;
    gap: 10px;
    text-align: center;
  }

  header h1 {
    font-size: 18px;
  }

  .cart-container {
    padding: 0 10px;
  }

  .cart-item {
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    padding: 15px;
  }

  .cart-item img {
    width: 100%;
    height: 180px;
  }

  .cart-details h4 {
    font-size: 16px;
  }

  .cart-details p {
    font-size: 14px;
  }

  .remove-btn {
    position: static;
    width: 100%;
    margin-top: 10px;
  }

  .checkout-btn {
    width: 100%;
    text-align: center;
    align-self: center;
  }
}

@media (max-width: 480px) {

  header h1 {
    font-size: 16px;
  }

  #cart-count {
    width: 20px;
    height: 20px;
    font-size: 12px;
  }

  .cart-item img {
    height: 150px;
  }

  .cart-details h4 {
    font-size: 15px;
  }

  .cart-details p {
    font-size: 13px;
  }
}

</style>
</head>
<body>

<header>
  <h1>Veek Cart</h1>
  <div>Cart: <span id="cart-count"><%= cartItems.reduce((sum,i)=>sum+i.quantity,0) %></span></div>
</header>

<h2 style="text-align:center; margin-top:20px;">Your Cart</h2>

<% if(cartItems.length === 0){ %>
  <p style="text-align:center;">Your cart is empty</p>
<% } else { %>
  <div class="cart-container">
    <% cartItems.forEach(item => { %>
      <div class="cart-item" data-id="<%= item._id %>">
        <img src="<%= item.images && item.images.length ? item.images[0] : '/images/default.png' %>" alt="<%= item.name %>">
        <div class="cart-details">
          <h4><%= item.name %></h4>
          <p>Price: <%= item.selectedPrice %> EGP</p>
          <p>Quantity: <%= item.quantity %></p>
          <p>Total: <%= item.selectedPrice * item.quantity %> EGP</p>
          <% if(item.selectedSize){ %><p>Size: <%= item.selectedSize %></p><% } %>
          <% if(item.selectedColor){ %><p>Color: <%= item.selectedColor %></p><% } %>
        </div>
        <button class="remove-btn">Remove</button>
      </div>
    <% }) %>
    <a href="/checkout/get" class="checkout-btn">Proceed to Checkout</a>
  </div>
<% } %>

<script>
document.querySelectorAll('.remove-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const parent = btn.closest('.cart-item');
    const productId = parent.dataset.id;

    try {
      const res = await fetch('/cart/remove', {
        method:'POST',
        headers:{ 'Content-Type':'application/json' },
        body: JSON.stringify({ productId })
      });
      const data = await res.json();
      if(data.success){
        parent.remove();
        document.getElementById('cart-count').innerText = data.totalQuantity || 0;
        if(document.querySelectorAll('.cart-item').length === 0){
          document.querySelector('.cart-container').innerHTML = '<p style="text-align:center;">Your cart is empty</p>';
        }
      }
    } catch(err){
      console.error(err);
      alert('Error removing product from cart');
    }
  });
});
</script>

</body>
</html>
