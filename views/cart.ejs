<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Your Cart</title>
  <style>
  body { 
  font-family: Arial; 
  margin:0; 
  padding:0; 
  background:#f4f4f4; 
}

/* Header */
header { 
  background:#000; 
  color:#fff; 
  padding:12px 15px; 
  display:flex; 
  justify-content:space-between; 
  align-items:center; 
  flex-wrap:wrap;
}

header h1 { 
  margin:0; 
  font-size:20px; 
}

/* Cart count */
#cart-count { 
  background:red; 
  color:white; 
  width:20px; 
  height:20px; 
  border-radius:50%; 
  display:flex; 
  align-items:center; 
  justify-content:center; 
  font-weight:bold; 
}

/* Container */
.cart-container { 
  display:flex; 
  flex-direction:column; 
  gap:15px; 
  max-width:800px; 
  margin:15px auto; 
  padding:0 10px;
}

/* Item */
.cart-item { 
  display:flex; 
  gap:15px; 
  align-items:center; 
  border:1px solid #ccc; 
  padding:10px; 
  border-radius:10px; 
  background:#fff; 
  position:relative; 
}

/* Image */
.cart-item img { 
  width:90px; 
  height:90px; 
  object-fit:cover; 
  border-radius:10px; 
}

/* Text */
.cart-details h4 { 
  margin:0; 
  font-size:16px; 
}

.cart-details p { 
  margin:4px 0; 
  font-size:14px;
}

/* Remove button */
.remove-btn { 
  position:absolute; 
  top:10px; 
  right:10px; 
  background:#dc3545; 
  color:#fff; 
  border:none; 
  padding:5px 10px; 
  border-radius:5px; 
  cursor:pointer; 
  font-size:12px;
}

/* Checkout */
.checkout-btn { 
  align-self:flex-end; 
  padding:10px 18px; 
  background:#007bff; 
  color:#fff; 
  text-decoration:none; 
  border-radius:5px; 
  font-size:14px;
}

/* ===================== */
/* MOBILE RESPONSIVE */
/* ===================== */
@media (max-width: 600px) {

  header {
    flex-direction:column;
    align-items:flex-start;
    gap:10px;
  }

  .cart-item {
    flex-direction:row;
    align-items:flex-start;
  }

  .cart-item img {
    width:70px;
    height:70px;
  }

  .cart-details h4 {
    font-size:14px;
  }

  .cart-details p {
    font-size:12px;
  }

  .remove-btn {
    padding:4px 8px;
    font-size:11px;
  }

  .checkout-btn {
    width:100%;
    text-align:center;
  }
}
  </style>
</head>
<body>

<header>
  <h1>Veek Cart</h1>
  <div>Cart: <span id="cart-count"><%= cartItems.reduce((sum,i)=>sum+i.quantity,0) %></span></div>
</header>

<h2 style="text-align:center; margin-top:20px;">Your Cart</h2>

<% if(cartItems.length === 0){ %>
  <p style="text-align:center;">Your cart is empty</p>
<% } else { %>
  <div class="cart-container">
    <% cartItems.forEach(item => { %>
      <div class="cart-item" data-id="<%= item._id %>">
        <img src="<%= item.images && item.images.length ? item.images[0] : '/images/default.png' %>" alt="<%= item.name %>">
        <div class="cart-details">
          <h4><%= item.name %></h4>
          <p>Price: <%= item.selectedPrice %> EGP</p>
          <p>Quantity: <%= item.quantity %></p>
          <p>Total: <%= item.selectedPrice * item.quantity %> EGP</p>
          <% if(item.selectedSize){ %><p>Size: <%= item.selectedSize %></p><% } %>
          <% if(item.selectedColor){ %><p>Color: <%= item.selectedColor %></p><% } %>
        </div>
        <button class="remove-btn">Remove</button>
      </div>
    <% }) %>
    <a href="/checkout/get" class="checkout-btn">Proceed to Checkout</a>
  </div>
<% } %>

<script>
document.querySelectorAll('.remove-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const parent = btn.closest('.cart-item');
    const productId = parent.dataset.id;

    try {
      const res = await fetch('/cart/remove', {
        method:'POST',
        headers:{ 'Content-Type':'application/json' },
        body: JSON.stringify({ productId })
      });
      const data = await res.json();
      if(data.success){
        parent.remove();
        document.getElementById('cart-count').innerText = data.totalQuantity || 0;
        if(document.querySelectorAll('.cart-item').length === 0){
          document.querySelector('.cart-container').innerHTML = '<p style="text-align:center;">Your cart is empty</p>';
        }
      }
    } catch(err){
      console.error(err);
      alert('Error removing product from cart');
    }
  });
});
</script>

</body>
</html>
