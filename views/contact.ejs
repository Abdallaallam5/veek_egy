<%- include("partials/header") %>
<style>
body {
    font-family: Arial, sans-serif;
    background: #f5f5f5;
    text-align: center;
    margin: 0;
    padding: 0;
}

.container {
    width: 500px;
    max-width: 90%; /* لتناسب الشاشات الصغيرة */
    margin: 80px auto;
    background: #fff;
    padding: 30px 20px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    border-radius: 10px;
    box-sizing: border-box;
}

h1 {
    margin-bottom: 30px;
    font-size: 28px;
    color: #333;
}

input, textarea {
    width: 100%;
    padding: 12px;
    margin: 10px 0;
    border: 1px solid #ccc;
    border-radius: 5px;
    box-sizing: border-box;
    font-size: 14px;
}

textarea {
    resize: vertical;
}

button {
    padding: 12px 30px;
    background: black;
    color: white;
    border: none;
    border-radius: 25px;
    cursor: pointer;
    font-size: 16px;
    transition: 0.3s;
}

button:hover {
    background: #333;
}

/* Responsive for Mobile */
@media (max-width: 480px) {
    .container {
        margin: 50px auto;
        padding: 20px 15px;
    }

    h1 {
        font-size: 24px;
        margin-bottom: 20px;
    }

    input, textarea {
        font-size: 14px;
        padding: 10px;
    }

    button {
        width: 100%;
        padding: 12px 0;
    }
}
</style>
</head>

<body>

<div class="container">
    <%= message ? `${message}` : '' %>
    <h1>Contact</h1>

    <form action="/contact" method="POST">
        <input type="text" name="name" placeholder="Name" required>

        <input type="email" name="email" placeholder="Email" required>

        <input type="text" name="phone" placeholder="Phone number">

        <textarea name="message" placeholder="Comment" rows="5" required></textarea>

        <button type="submit">Send</button>
    </form>
</div>

</body>
</html>
<%- include("partials/footer") %>