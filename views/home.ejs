<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Checkout</title>

<style>
body {
  font-family: Arial, sans-serif;
  background: #f7f8fc;
  margin: 0;
  padding: 0;
}

/* ===== LOADING ===== */
.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.55);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loader {
  background: #fff;
  padding: 25px;
  border-radius: 12px;
  text-align: center;
}

.spinner {
  width: 40px;
  height: 40px;
  border: 4px solid #eee;
  border-top: 4px solid #000;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: auto;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ===== CHECKOUT ===== */
.checkout {
  display: flex;
  max-width: 1100px;
  margin: 40px auto;
  gap: 30px;
}

.checkout-left,
.checkout-right {
  flex: 1;
  background: #fff;
  padding: 25px;
  border-radius: 10px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
}

.checkout-left h2 {
  margin: 10px 0;
}

.checkout-left input,
.checkout-left select {
  width: 100%;
  padding: 12px;
  margin-bottom: 12px;
  border: 1px solid #ddd;
  border-radius: 6px;
}

/* BUTTON */
.checkout-btn {
  width: 100%;
  padding: 12px;
  background: #000;
  color: #fff;
  border: none;
  border-radius: 8px;
  cursor: pointer;
}

/* ITEMS */
.order-item {
  display: flex;
  gap: 10px;
  margin-bottom: 15px;
}

.order-item img {
  width: 60px;
  height: 60px;
  object-fit: cover;
  border-radius: 8px;
}

.price-box {
  border-top: 1px solid #eee;
  padding-top: 15px;
}

.price-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
}

.total-row {
  font-weight: bold;
  color: #000;
}

/* COUPON */
.coupon {
  display: flex;
  gap: 10px;
  margin: 10px 0;
}

.coupon input {
  flex: 1;
  padding: 10px;
}

.coupon button {
  padding: 10px 12px;
  background: #000;
  color: #fff;
  border: none;
  cursor: pointer;
}

/* MOBILE */
@media (max-width:900px){
  .checkout { flex-direction: column; margin: 10px; }
}
</style>
</head>

<body>

<!-- LOADING -->
<div class="loading-overlay" id="loading">
  <div class="loader">
    <div class="spinner"></div>
    <p>Processing...</p>
  </div>
</div>

<form id="checkoutForm" onsubmit="event.preventDefault(); submitOrder();">

<div class="checkout">

  <!-- LEFT -->
  <div class="checkout-left">
    <h2>Contact</h2>

    <input name="name" placeholder="Full Name" required>
    <input name="email" placeholder="Email" required>
    <input name="phone" placeholder="Phone" required>

    <h2>Shipping</h2>
    <input name="address" placeholder="Address" required>

    <select name="city" id="citySelect" required>
      <option value="">Select Governorate</option>
      <% [
        "Cairo","Giza","Alexandria","Dakahlia","Red Sea","Beheira",
        "Fayoum","Gharbia","Ismailia","Menofia","Minya","Qaliubiya",
        "New Valley","Suez","Aswan","Assiut","Beni Suef","Port Said",
        "Damietta","Sharkia","South Sinai","Kafr El Sheikh","Matrouh",
        "Luxor","Qena","North Sinai","Sohag"
      ].forEach(g => { %>
        <option value="<%= g %>"><%= g %></option>
      <% }) %>
    </select>

    <button class="checkout-btn">Confirm Order</button>
  </div>

  <!-- RIGHT -->
  <div class="checkout-right">

    <% cartItems.forEach(item => { %>
      <div class="order-item">
        <img src="<%= item.images?.[0] || '/uploads/default.jpg' %>">

        <div>
          <h4><%= item.name %></h4>
          <p><%= item.selectedPrice %> EGP</p>
          <p>Qty: <%= item.quantity %></p>

          <input type="hidden" name="productId[]" value="<%= item._id %>">
          <input type="hidden" name="quantity[]" value="<%= item.quantity %>">
          <input type="hidden" name="price[]" value="<%= item.selectedPrice %>">
        </div>
      </div>
    <% }) %>

    <div class="price-box">

      <div class="price-row">
        <span>Subtotal</span>
        <span id="subtotal"><%= subtotal %> EGP</span>
      </div>

      <div class="coupon">
        <input id="couponCode" placeholder="Coupon">
        <button type="button" id="applyCoupon">Apply</button>
      </div>

      <p id="couponMessage"></p>

      <div class="price-row">
        <span>Discount</span>
        <span id="discount">0 EGP</span>
      </div>

      <div class="price-row">
        <span>Shipping</span>
        <span id="shipping"><%= shipping %> EGP</span>
      </div>

      <div class="price-row total-row">
        <span>Total</span>
        <span id="total"><%= subtotal + shipping %> EGP</span>
      </div>

    </div>
  </div>

</div>
</form>

<script>

/* ===== LOADING HELPERS ===== */
function showLoading() {
  document.getElementById("loading").style.display = "flex";
}
function hideLoading() {
  document.getElementById("loading").style.display = "none";
}

/* ===== UPDATE PRICES ===== */
async function updatePrices() {
  const couponCode = document.getElementById("couponCode").value;
  const subtotal = parseFloat(document.getElementById("subtotal").textContent) || 0;
  const governorate = document.getElementById("citySelect").value;

  if (!governorate) return;

  try {
    showLoading();

    const res = await fetch(`/checkout/calculate?subtotal=${subtotal}&code=${couponCode}&governorate=${encodeURIComponent(governorate)}`);
    const data = await res.json();

    if (data.success) {
      document.getElementById("discount").textContent = data.discount + " EGP";
      document.getElementById("shipping").textContent = data.shipping + " EGP";
      document.getElementById("total").textContent = data.total + " EGP";
      document.getElementById("couponMessage").textContent = data.message;
    }

  } finally {
    hideLoading();
  }
}

document.getElementById("citySelect").addEventListener("change", updatePrices);
document.getElementById("applyCoupon").addEventListener("click", updatePrices);

/* ===== SUBMIT ORDER ===== */
async function submitOrder() {
  try {
    showLoading();

    const form = document.getElementById("checkoutForm");
    const formData = new FormData(form);

    const productIds = formData.getAll("productId[]");
    const quantities = formData.getAll("quantity[]");
    const prices = formData.getAll("price[]");

    const products = productIds.map((id, i) => ({
      product: id,
      quantity: parseInt(quantities[i]),
      price: parseFloat(prices[i])
    }));

    const data = Object.fromEntries(formData.entries());

    const res = await fetch("/checkout/place-order", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        products,
        customerName: data.name,
        customerEmail: data.email,
        customerAddress: data.address,
        governorate: data.city,
        shipping: parseFloat(document.getElementById("shipping").textContent),
        discount: parseFloat(document.getElementById("discount").textContent),
        total: parseFloat(document.getElementById("total").textContent),
        couponCode: document.getElementById("couponCode").value || null
      })
    });

    const result = await res.json();

    if (res.ok) {
      window.location.href = "/";
    } else {
      alert(result.error || "Error");
    }

  } finally {
    hideLoading();
  }
}

</script>

</body>
</html>
