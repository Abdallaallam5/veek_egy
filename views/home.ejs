<%- include('partials/header') %>

<style>
/* ===== Hero Slider ===== */
.hero-slider {
  position: relative;
  height: 400px;
  overflow: hidden;
  margin-top: 90px; /* لتجنب التداخل مع navbar */
}
.category-title {
  font-size: 28px;        /* حجم الخط */
  font-weight: 900;       /* تقيل جداً */
  margin: 40px 15px 20px; /* المسافات حول العنوان */
  padding-left: 20px;     /* مساحة للخط الجانبي */
  position: relative;
  color: #1a1a1a;         /* لون الخط */
}

/* الخط الأسود الجانبي */
.category-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: 8px;             /* سمك الخط */
  background-color: #000; /* لون الخط أسود */
  border-radius: 4px;     /* حواف دائرية خفيفة للخط */
}

.slide {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.8s ease;
}

.slide.active {
  opacity: 1;
}

.slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: white;
  text-align: center;
  z-index: 5;
}

/* ===== Products Grid ===== */
.products-grid {
  display: grid;
  gap: 20px;
  margin: 40px 15px;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
}

/* ===== Product Card ===== */
.product-card {
  background: #fff;
  border-radius: 15px;
  overflow: hidden;
  box-shadow: 0 6px 20px rgba(0,0,0,0.1);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  display: flex;
  flex-direction: column;
  position: relative;
}

.product-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 12px 25px rgba(0,0,0,0.15);
}

.product-card img {
  width: 100%;
  /* بدلاً من height ثابت */
  aspect-ratio: 4/3; /* نسبة عرض/ارتفاع مناسبة للكارت */
  object-fit: cover;
  transition: transform 0.4s ease
};

.product-card:hover img {
  transform: scale(.95);
}

.product-card h3 {
  font-size: 16px;
  margin: 10px 15px 5px;
  color: #333;
  font-weight: 600;
}

.product-card .price {
  margin: 0 15px 10px;
  font-size: 18px;
  font-weight: 700;
  color: #000;
}

.product-card .old-price {
  text-decoration: line-through;
  color: #999;
  font-weight: 500;
  font-size: 16px;
  margin-right: 8px;
}

.sale-price {
  color: #e74c3c;
}

.product-actions {
  margin: 10px 15px 15px;
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.btn {
  flex: 1;
  padding: 10px 15px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  border: none;
  text-decoration: none;
  display: flex;
  justify-content: center;
  align-items: center;
}

.main-btn {
  background: #000;
  color: #fff;
}

.main-btn:hover {
  background: #333;
}

.view-btn {
  background: #f5f5f5;
  color: #333;
}

.view-btn:hover {
  background: #e0e0e0;
}

/* Badges */
.sale-badge, .out-of-stock {
  position: absolute;
  top: 15px;
  padding: 6px 12px;
  font-size: 12px;
  font-weight: 700;
  border-radius: 20px;
  color: #fff;
  z-index: 5;
}

.sale-badge {
  left: 15px;
  background: #e74c3c;
}

.out-of-stock {
  right: 15px;
  background: #7f8c8d;
}

.product-card:has(.out-of-stock) img {
  filter: grayscale(100%) brightness(0.7);
}

/* ===== Responsive ===== */
@media (max-width: 768px) {
  .hero-slider { height: 50vh; }
  .products-grid { grid-template-columns: repeat(2, 1fr); gap: 15px; margin: 30px 10px; }
  .product-card img {
    aspect-ratio: 4/3; /* يحافظ على تناسب الصورة */
  }
  .product-card h3 { font-size: 15px; }
  .product-card .price { font-size: 16px; }
}

@media (max-width: 480px) {
  .products-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; margin: 20px 5px; }
  .product-card img {
    aspect-ratio: 1; /* يحافظ على تناسب الصورة */
  }
  .product-card h3 { font-size: 14px; }
  .product-card .price { font-size: 15px; }
}

/* Smooth scroll */
html { scroll-behavior: smooth; }
</style>

<div class="hero-slider">
  <div class="slide active">
    <img src="/images/photo_2026-01-23_00-05-32.jpg">
    <div class="overlay"></div>
    <div class="content"></div>
  </div>
  <div class="slide">
    <img src="/images/photo_2026-01-23_00-05-32 (2).jpg">
    <div class="overlay"></div>
    <div class="content"></div>
  </div>
</div>

<% productsByCategory.forEach(section => { %>
  <div class="category-section">
    <p class="category-title"><strong><%= section.category.name %></strong></p>
    <div class="products-grid">
      <% section.products.forEach(product => { %>
        <div class="product-card">
          <% if(product.stock === 0) { %>
            <div class="out-of-stock">OUT OF STOCK</div>
          <% } %>
          <% if(product.salePrice && product.salePrice < product.price) { %>
            <div class="sale-badge">SALE</div>
          <% } %>

          <a href="/product/<%= product._id %>">
            <img src="<%= product.images && product.images.length ? product.images[0] : '/images/default.png' %>" alt="<%= product.name %>">
          </a>

          <h3><%= product.name %></h3>

          <p class="price">
            <% if(product.salePrice && product.salePrice < product.price) { %>
              <span class="old-price"><%= product.price %> EGP</span>
              <span class="sale-price"><%= product.salePrice %> EGP</span>
            <% } else { %>
              <%= product.price %> EGP
            <% } %>
          </p>

          <div class="product-actions">
            <% if(product.stock === 0 || product.stock === null) { %>
              <button class="btn disabled">Out of Stock</button>
            <% } else { %>
              <button class="btn main-btn add-to-cart-btn" 
                data-id="<%= product._id %>"
                data-name="<%= product.name %>"
                data-sizes='<%= JSON.stringify(product.sizes || []) %>'
                data-colors='<%= JSON.stringify(product.colors || []) %>'
                data-price="<%= product.salePrice || product.price %>">
                Add To Cart
              </button>
              <a href="/product/<%= product._id %>" class="btn view-btn">View</a>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
<% }) %>

<!-- Modal -->
<div id="optionsModal" class="modal" style="display:none;">
  <div class="modal-content">
    <span class="close">&times;</span>
    <h3 id="modalProductName"></h3>
    <div id="sizeContainer"></div>
    <div id="colorContainer"></div>
    <button id="confirmAdd" class="btn main-btn">Add To Cart</button>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
  // Hero Slider
  const slides = document.querySelectorAll(".slide");
  let index = 0;
  if (slides.length > 0) {
    setInterval(() => {
      slides[index].classList.remove("active");
      index = (index + 1) % slides.length;
      slides[index].classList.add("active");
    }, 4000);
  }

  // Cart Modal
  const modal = document.getElementById("optionsModal");
  const modalName = document.getElementById("modalProductName");
  const sizeContainer = document.getElementById("sizeContainer");
  const colorContainer = document.getElementById("colorContainer");
  const confirmBtn = document.getElementById("confirmAdd");
  let currentProductId = null;

  function updateCartBadge(totalQuantity) {
    document.querySelectorAll("#cart-count").forEach(el => {
      el.textContent = totalQuantity || 0;
    });
  }

  document.querySelectorAll(".add-to-cart-btn").forEach(btn => {
    btn.addEventListener("click", async () => {
      const sizes = JSON.parse(btn.dataset.sizes);
      const colors = JSON.parse(btn.dataset.colors);

      if (sizes.length || colors.length) {
        currentProductId = btn.dataset.id;
        modalName.textContent = btn.dataset.name;

        sizeContainer.innerHTML = sizes.length
          ? `<label>Size:</label><select id="modalSize">${sizes.map(s => `<option value="${s}">${s}</option>`).join('')}</select>`
          : "";
        colorContainer.innerHTML = colors.length
          ? `<label>Color:</label><select id="modalColor">${colors.map(c => `<option value="${c}">${c}</option>`).join('')}</select>`
          : "";

        modal.style.display = "flex";
      } else {
        try {
          const res = await fetch("/cart/add", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ productId: btn.dataset.id })
          });
          const data = await res.json();
          if(data.success){
            updateCartBadge(data.totalQuantity);
            btn.textContent = "Added!";
            setTimeout(() => btn.textContent = "Add To Cart", 2000);
          }
        } catch (err) {
          console.error(err);
        }
      }
    });
  });

  document.querySelector(".close").addEventListener("click", () => { modal.style.display = "none"; });
  window.addEventListener("click", (e) => { if(e.target===modal) modal.style.display = "none"; });

  confirmBtn.addEventListener("click", async () => {
    const size = document.getElementById("modalSize")?.value || null;
    const color = document.getElementById("modalColor")?.value || null;

    try {
      const res = await fetch("/cart/add", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ productId: currentProductId, size, color })
      });
      const data = await res.json();
      if(data.success){
        updateCartBadge(data.totalQuantity);
        modal.style.display = "none";
      }
    } catch (err) { console.error(err); }
  });
});
</script>

<%- include("partials/footer") %>