<%- include('partials/header') %>
<style>
/* ===== Hero Slider ===== */
.hero-slider {
  position: relative;
  height: 400px;
  overflow: hidden;
  margin-top: 90px;
}

.slide {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.8s ease;
}

.slide.active {
  opacity: 1;
}

.slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ===== Category Title ===== */
.category-title {
  font-size: 28px;
  font-weight: 900;
  margin: 40px 15px 20px;
  padding-left: 20px;
  position: relative;
  color: #1a1a1a;
}

.category-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: 8px;
  background-color: #000;
  border-radius: 4px;
}

/* ===== PRODUCTS GRID ===== */
.products-grid {
  display: grid;
  gap: 20px;
  margin: 40px 15px;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
}

/* ===== PRODUCT CARD (FIXED SIZE) ===== */
.product-card {
  background: #fff;
  border-radius: 15px;
  overflow: hidden;
  box-shadow: 0 6px 20px rgba(0,0,0,0.1);

  display: flex;
  flex-direction: column;

  position: relative;

  /* 🔥 أهم سطر */
  min-height: 360px;
  height: 100%;
}

/* ===== IMAGE ===== */
.product-card img {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  flex-shrink: 0;
}

/* ===== TITLE ===== */
.product-card h3 {
  font-size: 16px;
  margin: 10px 15px 5px;

  /* 🔥 يمنع اختلاف الطول */
  min-height: 40px;
  max-height: 40px;
  overflow: hidden;

  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;

  color: #333;
  font-weight: 600;
}

/* ===== PRICE ===== */
.product-card .price {
  margin: 0 15px 10px;
  font-size: 18px;
  font-weight: 700;
  color: #000;

  /* 🔥 تثبيت المساحة */
  min-height: 22px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.product-card .old-price {
  text-decoration: line-through;
  color: #999;
  font-weight: 500;
  font-size: 14px;
}

.sale-price {
  color: #e74c3c;
}

/* ===== ACTIONS ===== */
.product-actions {
  margin: auto 15px 15px;

  display: flex;
  gap: 10px;
}

.btn {
  flex: 1;
  padding: 10px 12px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  border: none;

  display: flex;
  justify-content: center;
  align-items: center;
}

.main-btn {
  background: #000;
  color: #fff;
}

.main-btn:hover {
  background: #333;
}

.view-btn {
  background: #f5f5f5;
  color: #333;
}

.view-btn:hover {
  background: #e0e0e0;
}

/* ===== BADGES ===== */
.sale-badge,
.out-of-stock {
  position: absolute;
  top: 12px;
  padding: 6px 10px;
  font-size: 11px;
  font-weight: 700;
  border-radius: 20px;
  color: #fff;
  z-index: 5;
}

.sale-badge {
  left: 12px;
  background: #e74c3c;
}

.out-of-stock {
  right: 12px;
  background: #7f8c8d;
}

/* ===== MOBILE ===== */
@media (max-width: 768px) {
  .hero-slider {
    height: 50vh;
  }

  .products-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    margin: 20px 8px;
  }

  .product-card {
    min-height: 340px; /* 🔥 ثبات في الموبايل */
  }

  .product-card h3 {
    font-size: 14px;
  }

  .product-card .price {
    font-size: 15px;
  }
}

/* ===== SMALL MOBILE ===== */
@media (max-width: 480px) {
  .products-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .product-card {
    min-height: 320px;
  }
}

/* Smooth scroll */
html {
  scroll-behavior: smooth;
}
  </style>
</head>
<body>
<div class="hero-slider">
  <div class="slide active"><img src="/images/photo1.jpg"></div>
  <div class="slide"><img src="/images/photo2.jpg"></div>
</div>

<% productsByCategory.forEach(section => { %>
  <div class="category-section">
    <p class="category-title"><%= section.category.name %></p>

    <div class="products-grid">
      <% section.products.forEach(product => { %>
        <div class="product-card">

          <img src="<%= product.images?.[0] || '/images/default.png' %>">

          <h3><%= product.name %></h3>

          <p class="price">
            <% if(product.salePrice && product.salePrice < product.price) { %>
              <span class="old-price"><%= product.price %></span>
              <span class="sale-price"><%= product.salePrice %></span>
            <% } else { %>
              <%= product.price %>
            <% } %>
          </p>

          <div class="product-actions">
            <button class="btn main-btn add-to-cart-btn"
              data-id="<%= product._id %>"
              data-name="<%= product.name %>"
              data-sizes='<%= JSON.stringify(product.sizes || []) %>'
              data-colors='<%= JSON.stringify(product.colors || []) %>'>
              Add To Cart
            </button>

            <a class="btn view-btn" href="/product/<%= product._id %>">View</a>
          </div>

        </div>
      <% }) %>
    </div>
  </div>
<% }) %>

<!-- MODAL -->
<div id="optionsModal" class="modal">
  <div class="modal-content">
    <span class="close">&times;</span>

    <h3 id="modalProductName"></h3>

    <div id="sizeContainer"></div>
    <div id="colorContainer"></div>

    <!-- ✅ QTY -->
    <div style="margin-top:10px;">
      <label>Qty:</label>
      <input type="number" id="modalQty" min="1" value="1" style="width:80px;">
    </div>

    <button id="confirmAdd" class="btn main-btn" style="margin-top:10px;">
      Add To Cart
    </button>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {

  /* slider */
  let index = 0;
  const slides = document.querySelectorAll(".slide");
  setInterval(() => {
    slides[index].classList.remove("active");
    index = (index + 1) % slides.length;
    slides[index].classList.add("active");
  }, 4000);

  /* modal */
  const modal = document.getElementById("optionsModal");
  const modalName = document.getElementById("modalProductName");
  const sizeContainer = document.getElementById("sizeContainer");
  const colorContainer = document.getElementById("colorContainer");
  const confirmBtn = document.getElementById("confirmAdd");

  let currentProductId = null;

  function updateCartBadge(totalQuantity) {
    document.querySelectorAll("#cart-count")
      .forEach(el => el.textContent = totalQuantity || 0);
  }

  document.querySelectorAll(".add-to-cart-btn").forEach(btn => {
    btn.addEventListener("click", () => {

      const sizes = JSON.parse(btn.dataset.sizes || "[]");
      const colors = JSON.parse(btn.dataset.colors || "[]");

      currentProductId = btn.dataset.id;
      modalName.textContent = btn.dataset.name;

      sizeContainer.innerHTML = sizes.length
        ? `<select id="modalSize">
            ${sizes.map(s => `<option value="${s}">${s}</option>`).join("")}
           </select>` : "";

      colorContainer.innerHTML = colors.length
        ? `<select id="modalColor">
            ${colors.map(c => `<option value="${c}">${c}</option>`).join("")}
           </select>` : "";

      document.getElementById("modalQty").value = 1;

      modal.style.display = "flex";
    });
  });

  document.querySelector(".close").onclick = () => modal.style.display = "none";
  window.onclick = (e) => { if(e.target === modal) modal.style.display = "none"; };

  confirmBtn.addEventListener("click", async () => {

    const size = document.getElementById("modalSize")?.value || null;
    const color = document.getElementById("modalColor")?.value || null;
    const qty = parseInt(document.getElementById("modalQty").value) || 1;

    const res = await fetch("/cart/add", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        productId: currentProductId,
        size,
        color,
        qty
      })
    });

    const data = await res.json();

    if(data.success){
      updateCartBadge(data.totalQuantity);
      modal.style.display = "none";
    }
  });

});
</script>

<%- include("partials/footer") %>
