<%- include('partials/header') %>

<style>
/* ===== HERO ===== */
.hero-slider {
  position: relative;
  height: 400px;
  overflow: hidden;
  margin-top: 90px;
}

.slide {
  position: absolute;
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: .6s;
}

.slide.active { opacity: 1; }

.slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ===== CATEGORY ===== */
.category-title {
  font-size: 28px;
  font-weight: 900;
  margin: 40px 15px 20px;
  padding-left: 20px;
  position: relative;
}

.category-title::before {
  content: "";
  position: absolute;
  left: 0;
  width: 8px;
  height: 100%;
  background: #000;
  border-radius: 4px;
}

/* ===== GRID ===== */
.products-grid {
  display: grid;
  gap: 20px;
  margin: 40px 15px;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
}

/* ===== CARD ===== */
.product-card {
  background: #fff;
  border-radius: 15px;
  overflow: hidden;
  box-shadow: 0 6px 20px rgba(0,0,0,0.1);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  display: flex;
  flex-direction: column;
  position: relative;
  cursor: pointer;
}

.product-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 12px 25px rgba(0,0,0,0.15);
}

.product-card img {
  width: 100%;
  aspect-ratio: 4/3;
  object-fit: cover;
}

/* ===== PRICE ===== */
.product-card .price {
  margin: 0 15px 10px;
  font-size: 18px;
  font-weight: 700;
}

.old-price {
  text-decoration: line-through;
  color: #999;
}

.sale-price {
  color: #e74c3c;
}

/* ===== BUTTONS ===== */
.product-actions {
  margin: 10px 15px 15px;
  display: flex;
  gap: 10px;
}

.btn {
  flex: 1;
  padding: 10px;
  border-radius: 10px;
  border: none;
  font-weight: 600;
  cursor: pointer;
}

.main-btn {
  background: #000;
  color: #fff;
}

.view-btn {
  background: #f5f5f5;
  color: #333;
}

/* BADGES */
.sale-badge,
.out-of-stock {
  position: absolute;
  top: 10px;
  padding: 6px 10px;
  font-size: 11px;
  border-radius: 20px;
  color: #fff;
}

.sale-badge { left: 10px; background: #e74c3c; }
.out-of-stock { right: 10px; background: #7f8c8d; }

/* ===== MODAL ===== */
.modal {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  display: none;
  justify-content: center;
  align-items: center;
}

.modal-content {
  background: #fff;
  padding: 20px;
  border-radius: 12px;
  width: 320px;
  position: relative;
}

.close {
  position: absolute;
  right: 10px;
  top: 10px;
  cursor: pointer;
}
/* ===== MOBILE GRID ===== */
@media (max-width: 900px) {
  .products-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    margin: 15px 8px;
  }

  /* ===== CARD CLEAN ===== */
  .product-card {
    border-radius: 12px;
  }

  .product-card img {
    aspect-ratio: 1 / 1;
  }

  /* ===== TITLE ===== */
  .product-card h3 {
    font-size: 13px;
    margin: 8px 10px 5px;
    line-height: 1.3;
    height: 32px;
    overflow: hidden;
  }

  /* ===== PRICE FIX (IMPORTANT) ===== */
  .product-card .price {
    font-size: 13px;
    margin: 0 10px 6px;
    flex-direction: column; /* 👈 ده أهم تعديل */
    align-items: flex-start;
    gap: 2px;
  }

  .old-price {
    font-size: 12px;
    color: #aaa;
  }

  .sale-price {
    font-size: 13px;
    font-weight: 700;
  }

  /* ===== BUTTONS CLEAN ===== */
  .product-actions {
    flex-direction: column;
    gap: 6px;
    margin: 8px 10px 10px;
  }

  .btn {
    font-size: 12px;
    padding: 8px;
    border-radius: 8px;
  }

  .view-btn {
    background: #eee;
  }

  /* ===== BADGES SMALL ===== */
  .sale-badge,
  .out-of-stock {
    font-size: 10px;
    padding: 4px 8px;
  }
}

/* ===== VERY SMALL PHONES ===== */
@media (max-width: 420px) {
  .product-card h3 {
    font-size: 12px;
  }

  .product-card .price {
    font-size: 12px;
  }

  .btn {
    font-size: 11px;
  }
}
</style>

<div class="hero-slider">
  <div class="slide active"><img src="/images/photo_2026-01-23_00-05-32.jpg"></div>
  <div class="slide"><img src="/images/photo_2026-01-23_00-05-32 (2).jpg"></div>
</div>

<% productsByCategory.forEach(section => { %>
  <div class="category-section">
    <p class="category-title"><%= section.category.name %></p>

    <div class="products-grid">

      <% section.products.forEach(product => { %>

        <!-- الكارد كله clickable -->
        <div class="product-card" data-href="/product/<%= product._id %>">

          <% if(product.stock === 0) { %>
            <div class="out-of-stock">OUT</div>
          <% } %>

          <% if(product.salePrice && product.salePrice < product.price) { %>
            <div class="sale-badge">SALE</div>
          <% } %>

          <img src="<%= product.images?.[0] || '/images/default.png' %>">

          <h3 style="margin:10px 15px;"><%= product.name %></h3>

          <p class="price">
            <% if(product.salePrice && product.salePrice < product.price) { %>
              <span class="old-price"><%= product.price %> EGP</span>
              <span class="sale-price"><%= product.salePrice %> EGP</span>
            <% } else { %>
              <span><%= product.price %> EGP</span>
            <% } %>
          </p>

          <div class="product-actions">

            <button class="btn main-btn add-to-cart-btn"
              data-id="<%= product._id %>"
              data-name="<%= product.name %>"
              data-sizes='<%= JSON.stringify(product.sizes || []) %>'
              data-colors='<%= JSON.stringify(product.colors || []) %>'
              onclick="event.stopPropagation()">
              Add To Cart
            </button>

            <a class="btn view-btn"
               href="/product/<%= product._id %>"
               onclick="event.stopPropagation()">
              View
            </a>

          </div>
        </div>

      <% }) %>

    </div>
  </div>
<% }) %>

<!-- MODAL -->
<div id="optionsModal" class="modal">
  <div class="modal-content">

    <span class="close">&times;</span>

    <h3 id="modalProductName"></h3>

    <div id="sizeContainer"></div>
    <div id="colorContainer"></div>

    <!-- ✅ QTY -->
    <div style="margin-top:10px;">
      <label>Qty:</label>
      <input type="number" id="modalQty" value="1" min="1" style="width:80px;">
    </div>

    <button id="confirmAdd" class="btn main-btn" style="margin-top:10px;">
      Add To Cart
    </button>

  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {

  /* ================= HERO SLIDER ================= */
  const slides = document.querySelectorAll(".slide");
  let index = 0;

  if (slides.length) {
    setInterval(() => {
      slides[index].classList.remove("active");
      index = (index + 1) % slides.length;
      slides[index].classList.add("active");
    }, 4000);
  }

  /* ================= PRODUCT CARD CLICK ================= */
  document.querySelectorAll(".product-card").forEach(card => {
    card.addEventListener("click", (e) => {

      // لو ضغط على زرار أو لينك ماينقلش
      if (e.target.closest(".add-to-cart-btn") || e.target.closest(".btn")) return;

      const link = card.querySelector("a");
      if (link) window.location.href = link.href;
    });
  });

  /* ================= MODAL ================= */
  const modal = document.getElementById("optionsModal");
  const modalName = document.getElementById("modalProductName");
  const sizeContainer = document.getElementById("sizeContainer");
  const colorContainer = document.getElementById("colorContainer");
  const confirmBtn = document.getElementById("confirmAdd");

  let currentProductId = null;

  /* ================= CART BADGE (FIX LIVE) ================= */
  function updateCartBadge(qty) {
    document.querySelectorAll("#cart-count").forEach(el => {
      el.textContent = qty;
    });
  }

  /* ================= ADD TO CART ================= */
  document.querySelectorAll(".add-to-cart-btn").forEach(btn => {
    btn.addEventListener("click", async (e) => {
      e.stopPropagation(); // مهم جداً

      const sizes = JSON.parse(btn.dataset.sizes || "[]");
      const colors = JSON.parse(btn.dataset.colors || "[]");

      currentProductId = btn.dataset.id;

      /* لو مفيش اختيار → أضف مباشرة */
      if (sizes.length === 0 && colors.length === 0) {
        try {
          const res = await fetch("/cart/add", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ productId: currentProductId })
          });

          const data = await res.json();

          if (data.success) {
            updateCartBadge(data.totalQuantity);

            btn.innerText = "Added ✓";
            setTimeout(() => btn.innerText = "Add To Cart", 1200);
          }
        } catch (err) {
          console.error(err);
        }
        return;
      }

      /* افتح المودال */
      modalName.textContent = btn.dataset.name;

      sizeContainer.innerHTML = sizes.length
        ? `<label>Size</label>
           <select id="modalSize">
             ${sizes.map(s => `<option value="${s}">${s}</option>`).join("")}
           </select>`
        : "";

      colorContainer.innerHTML = colors.length
        ? `<label>Color</label>
           <select id="modalColor">
             ${colors.map(c => `<option value="${c}">${c}</option>`).join("")}
           </select>`
        : "";

      modal.style.display = "flex";
    });
  });

  /* ================= CLOSE MODAL ================= */
  document.querySelector(".close").onclick = () => modal.style.display = "none";
  window.onclick = (e) => {
    if (e.target === modal) modal.style.display = "none";
  };

  /* ================= CONFIRM ADD ================= */
  confirmBtn.addEventListener("click", async () => {

    const size = document.getElementById("modalSize")?.value || null;
    const color = document.getElementById("modalColor")?.value || null;

    try {
      const res = await fetch("/cart/add", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          productId: currentProductId,
          size,
          color,
          qty: parseInt(document.getElementById("modalQty").value) || 1
        })
      });

      const data = await res.json();

      if (data.success) {
        updateCartBadge(data.totalQuantity);
        modal.style.display = "none";
      }

    } catch (err) {
      console.error(err);
    }
  });

});
</script>

<%- include("partials/footer") %>
