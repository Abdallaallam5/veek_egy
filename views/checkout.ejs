<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>

  <style>
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* ===== Layout ===== */
body {
  font-family: Arial, sans-serif;
  background-color: #f7f8fc;
  margin: 0;
  padding: 0;
}

.checkout {
  display: flex;
  max-width: 1100px;
  margin: 40px auto;
  gap: 30px;
}

/* ===== Left ===== */
.checkout-left {
  flex: 1;
  background-color: #fff;
  padding: 30px 25px;
  border-radius: 8px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
}

.checkout-left h2 {
  margin-bottom: 15px;
  color: #333;
  font-size: 20px;
  border-bottom: 1px solid #eee;
  padding-bottom: 5px;
}

.checkout-left input {
  width: 100%;
  padding: 12px 10px;
  margin-bottom: 15px;
  border: 1px solid #ccc;
  border-radius: 5px;
}

/* ===== 🎯 SELECT STYLE (التعديل الوحيد) ===== */
.checkout-left select {
  width: 100%;
  padding: 12px 40px 12px 12px;
  margin-bottom: 15px;
  border: 1px solid #ccc;
  border-radius: 5px;
  font-size: 14px;
  background-color: #fff;
  cursor: pointer;

  appearance: none;
  -webkit-appearance: none;
  -moz-appearance: none;

  background-image: url("data:image/svg+xml;charset=UTF-8,%3Csvg fill='%23666' height='18' viewBox='0 0 20 20' width='18' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M5 7l5 5 5-5z'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: right 12px center;
  background-size: 16px;
}

.checkout-left select:focus {
  border-color: #1e90ff;
  box-shadow: 0 0 5px rgba(30,144,255,0.2);
  outline: none;
}

/* ===== Button ===== */
.checkout-btn {
  width: 100%;
  padding: 12px;
  background-color: #1e90ff;
  color: #fff;
  border: none;
  border-radius: 6px;
  cursor: pointer;
}

/* ===== Right ===== */
.checkout-right {
  flex: 1;
  background-color: #fff;
  padding: 30px 25px;
  border-radius: 8px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
}

.order-item {
  display: flex;
  margin-bottom: 20px;
}

.order-item img {
  width: 80px;
  height: 80px;
  margin-right: 10px;
}

.price-row {
  display: flex;
  justify-content: space-between;
  margin: 10px 0;
}

.total-row {
  font-weight: bold;
  color: #1e90ff;
}

/* ===== Responsive ===== */
@media (max-width: 900px) {
  .checkout {
    flex-direction: column;
    margin: 10px;
  }

  .checkout-left select {
    padding: 10px 35px 10px 10px;
  }
}
</style>
</head>

<body>

<form id="checkoutForm">

<div class="checkout">

<div class="checkout-left">

<h2>Contact</h2>
<input name="name" placeholder="Full Name" required>
<input name="email" type="email" placeholder="Email" required>
<input name="phone" placeholder="Phone" required>

<h2>Shipping</h2>
<input name="address" placeholder="Address" required>

<!-- 👇 نفس السيلكت بدون تغيير -->
<select name="city" id="citySelect" required>
  <option value="">Select Governorate</option>
  <% [
    "Cairo","Giza","Alexandria","Dakahlia","Red Sea","Beheira",
    "Fayoum","Gharbia","Ismailia","Menofia","Minya","Qaliubiya",
    "New Valley","Suez","Aswan","Assiut","Beni Suef","Port Said",
    "Damietta","Sharkia","South Sinai","Kafr El Sheikh","Matrouh",
    "Luxor","Qena","North Sinai","Sohag"
  ].forEach(g => { %>
    <option value="<%= g %>"><%= g %></option>
  <% }) %>
</select>

<button class="checkout-btn">Confirm Order</button>

</div>

<div class="checkout-right">
<div class="price-row">
  <span>Total</span>
  <span>---</span>
</div>
</div>

</div>

</form>

</body>
</html>
