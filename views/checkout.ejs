<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkout</title>

<style>
/* ===== Checkout Page Layout ===== */
body {
  font-family: Arial, sans-serif;
  background-color: #f7f8fc;
  margin: 0;
  padding: 0;
}

.checkout {
  display: flex;
  max-width: 1100px;
  margin: 40px auto;
  gap: 30px;
}

/* ===== LEFT ===== */
.checkout-left {
  flex: 1;
  background-color: #fff;
  padding: 30px 25px;
  border-radius: 8px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
}

.checkout-left h2 {
  margin-bottom: 15px;
  color: #333;
  font-size: 20px;
  border-bottom: 1px solid #eee;
  padding-bottom: 5px;
}

.checkout-left input,
.checkout-left select {
  width: 100%;
  padding: 12px 10px;
  margin-bottom: 15px;
  border: 1px solid #ccc;
  border-radius: 5px;
  font-size: 14px;
  outline: none;
}

.checkout-left .checkout-btn {
  width: 100%;
  padding: 12px;
  background-color: #1e90ff;
  color: #fff;
  border: none;
  border-radius: 6px;
  font-size: 16px;
  cursor: pointer;
}

/* ===== RIGHT ===== */
.checkout-right {
  flex: 1;
  background-color: #fff;
  padding: 30px 25px;
  border-radius: 8px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
}

.order-item {
  display: flex;
  gap: 10px;
  margin-bottom: 20px;
  align-items: flex-start;
}

.order-item img {
  width: 70px;
  height: 70px;
  object-fit: cover;
  border-radius: 6px;
}

.order-item h4 {
  margin: 0;
  font-size: 14px;
}

.order-item p {
  font-size: 12px;
  margin: 2px 0;
}

.price-box {
  border-top: 1px solid #eee;
  padding-top: 15px;
}

.price-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
}

.total-row {
  font-weight: bold;
  font-size: 16px;
  color: #1e90ff;
}

#couponMessage {
  font-size: 13px;
  margin-top: 5px;
}

/* ===== COUPON ===== */
.coupon-section {
  display: flex;
  gap: 8px;
  margin: 10px 0;
}

.coupon-section input {
  flex: 1;
  padding: 8px;
}

.coupon-section button {
  padding: 8px 12px;
  background: #000;
  color: #fff;
  border: none;
  cursor: pointer;
}

/* ===== MOBILE ===== */
@media (max-width: 900px) {
  .checkout {
    flex-direction: column;
    margin: 10px;
  }

  .checkout-left,
  .checkout-right {
    padding: 15px;
  }

  .order-item img {
    width: 55px;
    height: 55px;
  }
}
</style>
</head>

<body>

<form id="checkoutForm" onsubmit="event.preventDefault(); submitOrder();">

<div class="checkout">

  <!-- LEFT -->
  <div class="checkout-left">

    <h2>Contact</h2>
    <input name="name" placeholder="Full Name" required>
    <input name="email" placeholder="Email" required>
    <input name="phone" placeholder="Phone" required>

    <h2>Shipping</h2>
    <input name="address" placeholder="Address" required>

    <select name="city" id="citySelect" required>
      <option value="">Select Governorate</option>
      <% [
        "Cairo","Giza","Alexandria","Dakahlia","Red Sea","Beheira",
        "Fayoum","Gharbia","Ismailia","Menofia","Minya","Qaliubiya",
        "New Valley","Suez","Aswan","Assiut","Beni Suef","Port Said",
        "Damietta","Sharkia","South Sinai","Kafr El Sheikh","Matrouh",
        "Luxor","Qena","North Sinai","Sohag"
      ].forEach(g => { %>
        <option value="<%= g %>"><%= g %></option>
      <% }) %>
    </select>

    <button type="submit" class="checkout-btn">Confirm Order</button>
  </div>

  <!-- RIGHT -->
  <div class="checkout-right">

    <% cartItems.forEach(item => { %>
      <div class="order-item">

        <img src="<%= item.images?.[0] || '/uploads/default.jpg' %>">

        <div>
          <h4><%= item.name %></h4>
          <p>Price: <%= item.selectedPrice %> EGP</p>
          <p>Qty: <%= item.quantity %></p>

          <input type="hidden" name="productId[]" value="<%= item._id %>">
          <input type="hidden" name="quantity[]" value="<%= item.quantity %>">
          <input type="hidden" name="price[]" value="<%= item.selectedPrice %>">
        </div>

      </div>
    <% }) %>

    <div class="price-box">

      <div class="price-row">
        <span>Subtotal</span>
        <span id="subtotal"><%= subtotal %> EGP</span>
      </div>

      <!-- COUPON -->
      <div class="coupon-section">
        <input type="text" id="couponCode" placeholder="Coupon code">
        <button type="button" id="applyCoupon">Apply</button>
      </div>

      <p id="couponMessage"></p>

      <div class="price-row">
        <span>Discount</span>
        <span id="discount">0 EGP</span>
      </div>

      <div class="price-row">
        <span>Shipping</span>
        <span id="shipping"><%= shipping %> EGP</span>
      </div>

      <div class="price-row total-row">
        <span>Total</span>
        <span id="total"><%= subtotal + shipping %> EGP</span>
      </div>

    </div>

  </div>

</div>
</form>

<script>

/* ===== CHECK REQUIRED FIELDS ===== */
function checkRequiredFields() {
  const inputs = document.querySelectorAll("[name='name'],[name='email'],[name='phone'],[name='address'],#citySelect");

  for (let el of inputs) {
    if (!el.value || el.value.trim() === "") return false;
  }
  return true;
}

/* ===== COUPON ===== */
async function updatePrices() {

  if (!checkRequiredFields()) {
    document.getElementById("couponMessage").textContent =
      "⚠️ لازم تدخل بياناتك الأول قبل استخدام الكوبون";
    document.getElementById("couponMessage").style.color = "red";
    return;
  }

  const couponCode = document.getElementById("couponCode").value;
  const subtotal = parseFloat(document.getElementById("subtotal").textContent) || 0;
  const city = document.getElementById("citySelect").value;

  const res = await fetch(
    `/checkout/calculate?subtotal=${subtotal}&code=${couponCode}&governorate=${city}`
  );

  const data = await res.json();

  if (data.success) {
    document.getElementById("discount").textContent = data.discount + " EGP";
    document.getElementById("shipping").textContent = data.shipping + " EGP";
    document.getElementById("total").textContent = data.total + " EGP";

    document.getElementById("couponMessage").textContent = data.message;
    document.getElementById("couponMessage").style.color = "green";
  }
}

document.getElementById("applyCoupon").addEventListener("click", updatePrices);

/* disable button UX */
document.querySelectorAll("input, select").forEach(el => {
  el.addEventListener("input", () => {
    document.getElementById("applyCoupon").disabled = !checkRequiredFields();
  });
});

/* ===== SUBMIT ===== */
async function submitOrder() {
  alert("Order submitted!");
}

</script>

</body>
</html>
