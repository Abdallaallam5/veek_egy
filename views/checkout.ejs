<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Checkout</title>

<style>
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

body {
  font-family: Arial, sans-serif;
  background-color: #f7f8fc;
  margin: 0;
}

/* ===== Layout ===== */
.checkout {
  display: flex;
  max-width: 1100px;
  margin: 40px auto;
  gap: 30px;
}

.checkout-left,
.checkout-right {
  flex: 1;
  background: #fff;
  padding: 25px;
  border-radius: 8px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
}

.checkout-left input {
  width: 100%;
  padding: 12px;
  margin-bottom: 15px;
  border: 1px solid #ccc;
  border-radius: 6px;
}

.checkout-btn {
  width: 100%;
  padding: 12px;
  background: #1e90ff;
  color: #fff;
  border: none;
  border-radius: 6px;
  cursor: pointer;
}

/* ===== Custom Select ===== */
.custom-select {
  position: relative;
  margin-bottom: 15px;
}

.select-box {
  padding: 12px;
  border: 1px solid #ccc;
  border-radius: 6px;
  background: #fff;
  cursor: pointer;
}

.options {
  position: absolute;
  width: 100%;
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 6px;
  margin-top: 5px;
  display: none;
  max-height: 220px;
  overflow-y: auto;
  z-index: 1000;
}

.option {
  padding: 10px;
  cursor: pointer;
}

.option:hover {
  background: #f0f4ff;
}

/* ===== Right ===== */
.order-item {
  display: flex;
  gap: 10px;
  margin-bottom: 20px;
}

.order-item img {
  width: 70px;
  height: 70px;
}

.price-row {
  display: flex;
  justify-content: space-between;
  margin: 8px 0;
}

.total-row {
  font-weight: bold;
  color: #1e90ff;
}

/* ===== Responsive ===== */
@media (max-width: 900px) {
  .checkout {
    flex-direction: column;
    margin: 10px;
  }
}
</style>
</head>

<body>

<div id="popupAlert" style="display:none;position:fixed;top:20px;left:50%;transform:translateX(-50%);padding:10px 20px;border-radius:10px;color:#fff;"></div>

<div id="loadingOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9999;align-items:center;justify-content:center;color:#fff;flex-direction:column;">
  <div style="width:40px;height:40px;border:4px solid #fff;border-top:4px solid transparent;border-radius:50%;animation:spin 1s linear infinite;"></div>
  Processing...
</div>

<form id="checkoutForm" onsubmit="event.preventDefault(); submitOrder();">

<div class="checkout">

<!-- LEFT -->
<div class="checkout-left">

<h3>Contact</h3>
<input name="name" placeholder="Full Name" required>
<input name="email" type="email" placeholder="Email" required>
<input name="phone" placeholder="Phone" required>

<h3>Shipping</h3>
<input name="address" placeholder="Address" required>

<!-- CUSTOM SELECT -->
<div class="custom-select">
  <div class="select-box" id="selectedCity">Select Governorate</div>

  <div class="options" id="cityOptions">
    <% [
      "Cairo","Giza","Alexandria","Dakahlia","Red Sea","Beheira",
      "Fayoum","Gharbia","Ismailia","Menofia","Minya","Qaliubiya",
      "New Valley","Suez","Aswan","Assiut","Beni Suef","Port Said",
      "Damietta","Sharkia","South Sinai","Kafr El Sheikh","Matrouh",
      "Luxor","Qena","North Sinai","Sohag"
    ].forEach(g => { %>
      <div class="option"><%= g %></div>
    <% }) %>
  </div>

  <input type="hidden" name="city" id="citySelect" required>
</div>

<button class="checkout-btn">Confirm Order</button>

</div>

<!-- RIGHT -->
<div class="checkout-right">

<% cartItems.forEach(item => { %>
<div class="order-item">
  <img src="<%= item.images?.[0] || '/uploads/default.jpg' %>">
  <div>
    <h4><%= item.name %></h4>
    <p><%= item.selectedPrice %> EGP</p>
    <p>Qty: <%= item.quantity %></p>

    <input type="hidden" name="productId[]" value="<%= item._id %>">
    <input type="hidden" name="quantity[]" value="<%= item.quantity %>">
    <input type="hidden" name="price[]" value="<%= item.selectedPrice %>">
  </div>
</div>
<% }) %>

<div class="price-box">
  <div class="price-row">
    <span>Subtotal</span>
    <span id="subtotal"><%= subtotal %></span>
  </div>

  <div class="price-row">
    <span>Shipping</span>
    <span id="shipping"><%= shipping %></span>
  </div>

  <div class="price-row total-row">
    <span>Total</span>
    <span id="total"><%= subtotal + shipping %></span>
  </div>
</div>

</div>

</div>
</form>

<script>
// popup
function popupAlert(msg,type="success"){
  const el=document.getElementById("popupAlert");
  el.innerText=msg;
  el.style.display="block";
  el.style.background=type==="error"?"red":"green";
  setTimeout(()=>el.style.display="none",2000);
}

// loading
function showLoading(){document.getElementById("loadingOverlay").style.display="flex";}
function hideLoading(){document.getElementById("loadingOverlay").style.display="none";}

// ===== CUSTOM SELECT =====
const selectBox=document.getElementById("selectedCity");
const optionsBox=document.getElementById("cityOptions");
const hiddenInput=document.getElementById("citySelect");

selectBox.onclick=()=>{
  optionsBox.style.display=optionsBox.style.display==="block"?"none":"block";
};

document.querySelectorAll(".option").forEach(opt=>{
  opt.onclick=()=>{
    selectBox.textContent=opt.textContent;
    hiddenInput.value=opt.textContent;
    optionsBox.style.display="none";
    updatePrices();
  };
});

document.addEventListener("click",(e)=>{
  if(!e.target.closest(".custom-select")){
    optionsBox.style.display="none";
  }
});

// ===== UPDATE PRICES =====
async function updatePrices(){
  const governorate=hiddenInput.value;
  if(!governorate) return;

  const subtotal=parseFloat(document.getElementById("subtotal").textContent)||0;

  const res=await fetch(`/checkout/calculate?subtotal=${subtotal}&governorate=${governorate}`);
  const data=await res.json();

  document.getElementById("shipping").textContent=data.shipping;
  document.getElementById("total").textContent=data.total;
}

// ===== SUBMIT =====
async function submitOrder(){
  showLoading();

  const form=new FormData(document.getElementById("checkoutForm"));

  const res=await fetch("/checkout/place-order",{
    method:"POST",
    body:JSON.stringify(Object.fromEntries(form)),
    headers:{"Content-Type":"application/json"}
  });

  if(res.ok){
    popupAlert("Order Done");
  }else{
    popupAlert("Error","error");
  }

  hideLoading();
}
</script>

</body>
</html>
