<%- include('partials/header') %>
<div class="container product-page">

  <div class="row align-items-start">

    <!-- الصور -->
<div class="col-md-6">
  <div class="slider">
    <button class="nav prev" onclick="prevSlide()">❮</button>

    <div class="main-image">
      <img id="mainProductImage" src="<%= product.images[0] %>">
    </div>

    <button class="nav next" onclick="nextSlide()">❯</button>
  </div>

  <div class="thumbs">
    <% product.images.forEach((img, i) => { %>
      <img src="<%= img %>" onclick="setSlide(<%= i %>)">
    <% }) %>
  </div>
</div>
    <!-- التفاصيل -->
    <div class="col-md-6 product-info">

      <form action="/checkout/get" method="GET" class="add-to-cart-form mt-4">
        <input type="hidden" name="productId" value="<%= product._id %>">
        <h1 class="product-title"><%= product.name %></h1>

        <div class="price">
          <% if(product.salePrice && product.salePrice < product.price){ %>
            <span class="old"><%= product.price %> EGP</span>
            <span class="new"><%= product.salePrice %> EGP</span>
            <span class="badge-sale">Sale</span>
          <% } else { %>
            <span class="new"><%= product.price %> EGP</span>
          <% } %>
        </div>

        <p class="desc"><%= product.description %></p>

        <!-- Color -->
        <label>Color</label>
        <select name="color" class="select-box">
          <% product.colors.forEach(color => { %>
            <option value="<%= color %>"><%= color %></option>
          <% }) %>
        </select>

        <!-- Size -->
        <label>Size</label>
        <select name="size" class="select-box">
          <% product.sizes.forEach(size => { %>
            <option><%= size %></option>
          <% }) %>
        </select>

        <!-- Quantity -->
        <div class="qty-box">
          <button type="button" onclick="changeQty(-1)">-</button>
          <input id="qty" name="qty" type="number" value="1" min="1">
          <button type="button" onclick="changeQty(1)">+</button>
        </div>
<div>
  <a 
    href="/size-guide" 
    style="
      display:inline-block;
      color:#111;
      font-size:15px;
      font-weight:600;
      text-decoration:none;
      border-bottom:1px solid #111;
      padding-bottom:2px;
      transition:0.3s;
    "
    onmouseover="this.style.color='#0d6efd';this.style.borderColor='#0d6efd';"
    onmouseout="this.style.color='#111';this.style.borderColor='#111';"
  >
    Size Guide
  </a>
</div>
        <!-- Buttons -->
        <button id="confirmAdd" class="btn-cart">Add to cart</button>
        <button class="btn-buy">Buy it now</button>
      </form>
    </div>

  </div>
</div>
<%- include('partials/footer') %>

<style>
  .slider {
  position: relative;
}

.nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: black;
  color: white;
  border: none;
  padding: 10px 15px;
  cursor: pointer;
  z-index: 2;
  opacity: 0.7;
}

.nav:hover {
  opacity: 1;
}

.prev {
  left: 10px;
}

.next {
  right: 10px;
}
.product-page {
  margin-top: 50px;
}

/* الصورة الكبيرة - ثابتة */
.main-image {
  width: 100%;
  height: 500px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
}

.main-image img {
  width: 100%;
  height: 100%;
  object-fit: contain; /* يخلي الصورة كلها تظهر */
  background: #f5f5f5; /* خلفية عشان الفراغ */
}

/* الصور الصغيرة */
.thumbs {
  display: flex;
  gap: 10px;
  margin-top: 15px;
}

.thumbs img {
  width: 80px;
  height: 80px;
  object-fit: cover;
  border-radius: 6px;
  transition: 0.3s;
}

.thumbs img:hover {
  border: 2px solid black;
  transform: scale(1.05);
}

/* العنوان */
.product-title {
  font-size: 28px;
  font-weight: 500;
}

/* السعر */
.price {
  margin: 15px 0;
}

.price .old {
  text-decoration: line-through;
  color: gray;
  margin-right: 10px;
}

.price .new {
  font-size: 20px;
  font-weight: bold;
}

.badge-sale {
  background: red;
  color: white;
  padding: 3px 10px;
  font-size: 12px;
  margin-left: 10px;
}

/* select */
.select-box {
  width: 100%;
  padding: 10px;
  margin-bottom: 15px;
}

/* الكمية */
.qty-box {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 15px 0;
}

.qty-box button {
  width: 40px;
  height: 40px;
}

/* الأزرار */
.btn-cart {
  width: 100%;
  padding: 15px;
  border: 2px solid black;
  background: white;
  margin-bottom: 10px;
}

.btn-buy {
  width: 100%;
  padding: 15px;
  background: black;
  color: white;
}

/* وصف المنتج - ثابت الحجم مع scroll */
.desc {
  max-height: 300px;
  overflow-y: auto;
  margin-bottom: 15px;
}

/* تحسين الموبايل */
@media (max-width: 768px) {
  .main-image {
    height: 300px;
  }

  .desc {
    max-height: 200px;
  }
}
</style>

<script>
  // تغيير الصورة الرئيسية
  function changeImage(src){
    document.getElementById("mainProductImage").src = src;
  }

  // تعديل الكمية
  function changeQty(amount){
    let qty = document.getElementById("qty");
    let value = parseInt(qty.value) || 1;
    value += amount;
    if(value < 1) value = 1;
    qty.value = value;
  }

  // ✅ AJAX Add to Cart
  document.getElementById('confirmAdd').addEventListener('click', async (e) => {
    e.preventDefault();

    const form = document.querySelector('.add-to-cart-form');
    const productId = form.querySelector('input[name="productId"]').value;
    const color = form.querySelector('select[name="color"]').value;
    const size = form.querySelector('select[name="size"]').value;
    const qty = parseInt(form.querySelector('input[name="qty"]').value) || 1;

    try {
      const res = await fetch('/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, color, size, qty })
      });

      const data = await res.json();

      if(data.success){
        const cartCount = document.getElementById('cart-count');
        if(cartCount) cartCount.innerText = data.totalQuantity || 0;
      } else {
        alert(data.error || '❌ Error adding product to cart');
      }

    } catch(err){
      console.error(err);
      alert('❌ Error adding product to cart');
    }
  });
  let images = <%- JSON.stringify(product.images) %>;
  let currentIndex = 0;

  function showImage(index){
    currentIndex = index;
    document.getElementById("mainProductImage").src = images[currentIndex];
  }

  function nextSlide(){
    currentIndex = (currentIndex + 1) % images.length;
    showImage(currentIndex);
  }

  function prevSlide(){
    currentIndex = (currentIndex - 1 + images.length) % images.length;
    showImage(currentIndex);
  }

  function setSlide(index){
    showImage(index);
  }
</script>
