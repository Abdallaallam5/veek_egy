<%- include('partials/header') %>

<div class="container product-page">
  <div class="row align-items-start g-4">

    <!-- الصور -->
    <div class="col-md-6">
      <div class="slider">

        <button class="nav prev" onclick="prevSlide()"></button>

        <div class="main-image">
          <img id="mainProductImage" src="<%= product.images[0] %>" alt="<%= product.name %>">
        </div>

        <button class="nav next" onclick="nextSlide()"></button>

      </div>

      <div class="thumbs">
        <% product.images.forEach((img, i) => { %>
          <img src="<%= img %>" onclick="setSlide(<%= i %>)">
        <% }) %>
      </div>
    </div>

    <!-- التفاصيل -->
    <div class="col-md-6 product-info">

      <form action="/checkout/get" method="GET" class="add-to-cart-form mt-4">

        <input type="hidden" name="productId" value="<%= product._id %>">

        <h1 class="product-title"><%= product.name %></h1>

        <div class="price">
          <% if(product.salePrice && product.salePrice < product.price){ %>
            <span class="old"><%= product.price %> EGP</span>
            <span class="new"><%= product.salePrice %> EGP</span>
            <span class="badge-sale">Sale</span>
          <% } else { %>
            <span class="new"><%= product.price %> EGP</span>
          <% } %>
        </div>

        <p class="desc"><%= product.description %></p>

        <label>Color</label>
        <select name="color" class="select-box">
          <% product.colors.forEach(color => { %>
            <option value="<%= color %>"><%= color %></option>
          <% }) %>
        </select>

        <label>Size</label>
        <select name="size" class="select-box">
          <% product.sizes.forEach(size => { %>
            <option value="<%= size %>"><%= size %></option>
          <% }) %>
        </select>

        <div class="qty-box">
          <button type="button" onclick="changeQty(-1)">-</button>
          <input id="qty" name="qty" type="number" value="1" min="1">
          <button type="button" onclick="changeQty(1)">+</button>
        </div>

        <div class="mb-3">
          <a href="/size-guide" class="size-guide-link">Size Guide</a>
        </div>

        <button id="confirmAdd" class="btn-cart">Add to cart</button>
        <button class="btn-buy">Buy it now</button>

      </form>
    </div>

  </div>
</div>

<%- include('partials/footer') %>

<style>
.product-page{
  margin-top:50px;
}

/* ================= slider ================= */
.slider{
  position:relative;
  width:100%;
  max-width:100%;
  overflow:hidden;
}

.main-image{
  width:100%;
  height:500px;
  background:#f5f5f5;
  display:flex;
  align-items:center;
  justify-content:center;
  border-radius:10px;
  overflow:hidden;
}

.main-image img{
  width:100%;
  height:100%;
  object-fit:contain;
}

/* arrows */
.nav{
  position:absolute;
  top:50%;
  transform:translateY(-50%);
  width:42px;
  height:42px;
  border:none;
  border-radius:50%;
  background:rgba(0,0,0,.7);
  color:#fff;
  font-size:20px;
  cursor:pointer;
  z-index:5;
}

.prev{ left:10px; }
.next{ right:10px; }

/* thumbs */
.thumbs{
  display:flex;
  gap:10px;
  margin-top:15px;
  flex-wrap:wrap;
}

.thumbs img{
  width:75px;
  height:75px;
  object-fit:cover;
  border-radius:8px;
  cursor:pointer;
  border:1px solid #eee;
}

/* ================= info ================= */
.product-title{
  font-size:28px;
  font-weight:600;
}

.price{
  margin:15px 0;
}

.price .old{
  color:#888;
  text-decoration:line-through;
  margin-right:10px;
}

.price .new{
  font-size:22px;
  font-weight:700;
}

.badge-sale{
  background:red;
  color:#fff;
  padding:4px 10px;
  font-size:12px;
  border-radius:20px;
}

.desc{
  max-height:220px;
  overflow:auto;
  margin-bottom:15px;
}

.select-box{
  width:100%;
  padding:12px;
  margin-bottom:15px;
}

.qty-box{
  display:flex;
  align-items:center;
  gap:10px;
  margin:15px 0;
}

.qty-box button{
  width:40px;
  height:40px;
  border:none;
  background:#111;
  color:#fff;
}

.qty-box input{
  width:70px;
  text-align:center;
  height:40px;
}

.size-guide-link{
  display:inline-block;
  color:#111;
  text-decoration:none;
  border-bottom:1px solid #111;
  font-weight:600;
}

.btn-cart,
.btn-buy{
  width:100%;
  padding:14px;
  border:none;
  margin-bottom:10px;
}

.btn-cart{
  background:#fff;
  border:2px solid #111;
}

.btn-buy{
  background:#111;
  color:#fff;
}

/* ================= mobile ================= */
@media (max-width:768px){

  .product-page{
    margin-top:20px;
    padding-left:12px;
    padding-right:12px;
  }

  .main-image{
    height:320px;
  }

  .nav{
    width:36px;
    height:36px;
    font-size:16px;
  }

  .prev{ left:6px; }
  .next{ right:6px; }

  .thumbs{
    justify-content:center;
    gap:8px;
  }

  .thumbs img{
    width:60px;
    height:60px;
  }

  .product-title{
    font-size:24px;
    margin-top:15px;
  }

}
</style>

<script>
function changeQty(amount){
  let qty = document.getElementById("qty");
  let value = parseInt(qty.value) || 1;
  value += amount;
  if(value < 1) value = 1;
  qty.value = value;
}

/* ajax add to cart */
document.getElementById('confirmAdd').addEventListener('click', async (e) => {
  e.preventDefault();

  const form = document.querySelector('.add-to-cart-form');

  const productId = form.querySelector('input[name="productId"]').value;
  const color = form.querySelector('select[name="color"]').value;
  const size = form.querySelector('select[name="size"]').value;
  const qty = parseInt(form.querySelector('input[name="qty"]').value) || 1;

  try{
    const res = await fetch('/cart/add',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({productId,color,size,qty})
    });

    const data = await res.json();

    if(data.success){
      const cartCount = document.getElementById('cart-count');
      if(cartCount) cartCount.innerText = data.totalQuantity || 0;
    }else{
      alert(data.error || 'Error');
    }

  }catch(err){
    alert('Error');
  }
});

/* slider */
let images = <%- JSON.stringify(product.images) %>;
let currentIndex = 0;

function showImage(index){
  currentIndex = index;
  document.getElementById("mainProductImage").src = images[currentIndex];
}

function nextSlide(){
  currentIndex = (currentIndex + 1) % images.length;
  showImage(currentIndex);
}

function prevSlide(){
  currentIndex = (currentIndex - 1 + images.length) % images.length;
  showImage(currentIndex);
}

function setSlide(index){
  showImage(index);
}
</script>
